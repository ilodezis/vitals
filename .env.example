# ─────────────────────────────────────────────────────────────────────────────
# Vitals — environment template. Copy to `.env` and fill in. NEVER commit `.env`.
# All app env vars are prefixed VITALS_ (mirrors Boxly's BOXLY_ convention).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# In docker-compose the host is the `vitals_db` service. For local dev against a
# host Postgres use 127.0.0.1.
VITALS_DATABASE_URL=postgresql+asyncpg://vitals:vitals_secret@vitals_db:5432/vitals_db

# Optional pool / timeout tuning (sensible defaults applied when unset).
# VITALS_DB_STATEMENT_TIMEOUT_MS=10000
# VITALS_DB_POOL_SIZE=20
# VITALS_DB_MAX_OVERFLOW=10
# VITALS_DB_POOL_TIMEOUT=30
# VITALS_DB_POOL_RECYCLE=1800

# Used by docker-compose to provision the Postgres + backup containers.
VITALS_DB_USER=vitals
VITALS_DB_PASSWORD=change_me_db_password
VITALS_DB_NAME=vitals_db
VITALS_BACKUP_RETENTION_DAYS=7

# ── Redis (scheduler locks + Garmin session cache) ───────────────────────────
VITALS_REDIS_URL=redis://vitals_redis:6379/0
# If you enable a Redis password, set it here AND embed it in the URL above:
#   redis://:<password>@vitals_redis:6379/0
VITALS_REDIS_PASSWORD=

# ── Time ─────────────────────────────────────────────────────────────────────
# All business "now"/"today" resolves against this zone (never the server clock).
VITALS_TIMEZONE=Europe/Chisinau

# ── Auth (single user) ───────────────────────────────────────────────────────
# Session cookie is signed with this secret (itsdangerous). Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
VITALS_SESSION_SECRET=change_me_session_secret
VITALS_AUTH_USERNAME=timur
# bcrypt hash of your password. Generate with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"
VITALS_AUTH_PASSWORD_HASH=
# Set to false ONLY for local http dev (secure cookies require https).
VITALS_COOKIE_SECURE=true
# Session cookie SameSite policy (lax | strict | none). 'lax' is the primary CSRF
# defence; only change if you understand the trade-off.
# VITALS_COOKIE_SAMESITE=lax
# Session lifetime in seconds (default 30 days).
# VITALS_SESSION_TTL=2592000

# ── Model Context Protocol (MCP) ─────────────────────────────────────────────
# Static client credentials configured when adding Vitals as a Custom Connector in Claude.ai
VITALS_MCP_CLIENT_ID=vitals-claude-connector
# REQUIRED — the /oauth/token endpoint refuses to issue access tokens while this
# is empty (fail-closed; an unconfigured secret must never act as a wildcard).
VITALS_MCP_CLIENT_SECRET=generate_a_secure_random_string_using_secrets_module
# Comma-separated allowlist of OAuth redirect_uri values the authorize/token
# endpoints will accept. Defaults to Claude.ai's custom-connector callback
# (same URI across web/desktop/mobile/Cowork) — override only if Anthropic
# changes it or you're testing against a different host.
# VITALS_MCP_REDIRECT_URIS=https://claude.ai/api/mcp/auth_callback


# ── Body composition (Navy formula + InBody/МедАсс BIA) ──────────────────────
VITALS_HEIGHT_CM=190
# male | female — the female Navy formula needs the hip measurement and is gated
# behind this flag for the open-source build (single user is male).
VITALS_SEX=male
# Which body-fat%/LBM source is "primary" for the goal-progress card when both a
# Navy (tape) estimate and a BIA scan exist: latest | navy | bia. "latest" prefers
# the BIA scan whenever one exists (falls back to Navy otherwise) — it's not a
# "most recent date" contest. Both series are always drawn on the chart regardless.
# The BIA scan upload uses the PARSER model below (vision); enable/disable the
# whole feature via the "Body composition" toggle in /settings.
VITALS_BODY_FAT_SOURCE=latest

# ── User profile (LLM context) ───────────────────────────────────────────────
# Frames the weekly digest and the "copy to chat" LLM export so the AI reads your
# data with the right context. Unset → the built-in defaults (Timur's profile) are
# used — set these to your own so you don't inherit them. Also editable in /settings.
VITALS_USER_AGE=18
# One-line description of what you're doing (goal + method).
VITALS_USER_PROGRAM=body recomposition on GLP-1 with strength training
# Comma-separated goals.
VITALS_USER_GOALS=fat loss,muscle retention

# ── Nutrition goals ──────────────────────────────────────────────────────────
# Daily targets for the nutrition dashboard. Can also be set from /settings.
VITALS_NUTRITION_PROTEIN_TARGET_G=150
VITALS_NUTRITION_CALORIES_MIN=1300
VITALS_NUTRITION_CALORIES_MAX=1700

# ── LLM gateway (OpenRouter, OpenAI-compatible) ──────────────────────────────
VITALS_OPENROUTER_API_KEY=
VITALS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional attribution headers OpenRouter surfaces on its dashboard.
VITALS_OPENROUTER_HTTP_REFERER=https://github.com/ilodezis/vitals
VITALS_OPENROUTER_X_TITLE=Vitals
# Per-task model slugs. Use an EXACT OpenRouter slug (a versioned id like
# ...-sonnet-4.6, not a "-latest" alias — OpenRouter rejects unknown aliases).
# DIGEST = weekly analytical narrative (reasoning + Russian prose).
# PARSER = vision extraction of lab PDFs/photos → JSON (must be vision-capable).
VITALS_LLM_MODEL_DIGEST=anthropic/claude-sonnet-4.6
VITALS_LLM_MODEL_PARSER=google/gemini-2.5-flash

# ── Hevy (workouts) ──────────────────────────────────────────────────────────
# Personal API key from the Hevy app (Settings → API). Empty → the workouts
# module renders but the "Sync" button is disabled. Synced every 6h.
VITALS_HEVY_API_KEY=
# VITALS_HEVY_BASE_URL=https://api.hevyapp.com

# ── Garmin Connect ───────────────────────────────────────────────────────────
# Garmin has no official API; these credentials drive a web session (garminconnect
# + garth). The OAuth token session is cached in Redis + on disk to avoid frequent
# logins (which can trigger a captcha/MFA and a temporary block). If Garmin demands
# MFA, a critical alert is raised — pre-seed the token store out-of-band to recover.
VITALS_GARMIN_EMAIL=
VITALS_GARMIN_PASSWORD=
# Directory the garth token store is persisted to (mount a volume in prod).
VITALS_GARMIN_TOKEN_DIR=/data/garmin_session

# ── External read-only API ───────────────────────────────────────────────────
# Shared secret for GET /external/summary — a compact, read-only health glance
# payload (weight trend, today's macros, recovery, logging streaks) for a
# separate personal dashboard app to read server-to-server. Empty = disabled
# (the endpoint responds 503, not a wildcard-open door).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
VITALS_EXTERNAL_API_TOKEN=

# ── Testing ──────────────────────────────────────────────────────────────────
# Point the suite at a real Postgres to exercise JSONB / GIN / partial-unique
# (scripts/test_postgres.sh sets this automatically). Unset → SQLite + skipped
# @integration tests.
# VITALS_TEST_DATABASE_URL=postgresql+asyncpg://postgres:testpass@127.0.0.1:55432/vitals_test
